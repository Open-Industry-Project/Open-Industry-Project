[gd_resource type="Shader" format=3 uid="uid://wtu5yyfpdcgl"]

[resource]
code = "shader_type spatial;
render_mode shadows_disabled;

uniform sampler2D metal_texture : source_color, filter_linear_mipmap, repeat_enable;
instance uniform float Scale = 1.0;
uniform vec3 color_tint : source_color = vec3(1.8, 1.8, 1.8);
uniform float Metallic = 0.94;
uniform float Roughness = 0.5;
uniform float Specular = 0.5;

const int BEAM_MAX = 16;
uniform int beam_count = 0;
uniform vec3 beam_starts[BEAM_MAX];
uniform vec3 beam_ends[BEAM_MAX];
uniform float beam_radius = 0.05;

varying vec3 world_pos;

void vertex() {
	world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
}

bool in_beam(vec3 pos, vec3 beam_start, vec3 beam_end) {
	vec3 ab = beam_end - beam_start;
	float ab_sq = dot(ab, ab);
	if (ab_sq < 0.0001) { return false; }
	float t = clamp(dot(pos - beam_start, ab) / ab_sq, 0.0, 1.0);
	vec3 closest = beam_start + t * ab;
	return length(pos - closest) < beam_radius;
}

void fragment() {
	vec2 scaled_uv = UV * vec2(1.0, round(Scale));
	ALBEDO = texture(metal_texture, scaled_uv).rgb * color_tint;
	METALLIC = Metallic;
	ROUGHNESS = Roughness;
	SPECULAR = Specular;

	for (int i = 0; i < BEAM_MAX; i++) {
		if (i >= beam_count) { break; }
		if (in_beam(world_pos, beam_starts[i], beam_ends[i])) { discard; }
	}
}
"
