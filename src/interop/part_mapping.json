{
  "$comment": "CANONICAL single source of truth for OIP web <-> Godot-native scene transfer. Imported by the web round-trip test (src/interop) AND vendored verbatim into the Godot repo (Open-Industry-Project/src/interop/part_mapping.json) so the GDScript bridge applies the same mapping. Adding/renaming a param on either surface without updating this file should make the round-trip golden test fail. See docs/scene-interop.md.",
  "version": 1,
  "coordinateSystem": {
    "units": "meters",
    "handedness": "right",
    "axes": "+X flow, +Y up, +Z side",
    "eulerOrder": "YXZ",
    "$comment": "Web stores position[3] + rotationY/X/Z (radians, YXZ). Godot stores Transform3D(basis, origin). transform.ts ports three.js Euler 'YXZ' <-> Godot Basis.from_euler(.., EULER_ORDER_YXZ)."
  },
  "convertKinds": {
    "identity": "value copied verbatim (number/bool/string/array)",
    "color": "web '#rrggbb' / '#rrggbbaa' <-> Godot Color (alpha auto-detected: dropped when 1.0)",
    "enumMap": "web enum string <-> Godot enum int via the per-param enumMap table",
    "segments": "web [{length, tiltDeg}] <-> Godot Array[BeltSegment] [{length, tilt_relative_deg}]",
    "tagFanout": "web single `tag` string -> the Godot `godot` field AND every field in `alsoGodot`",
    "partRef": "web part id <-> Godot NodePath/Node3D (resolved two-pass on import, read back on export)",
    "degToRad": "web degrees <-> Godot radians (Godot stores some angles via deg_to_rad())",
    "vec3": "several web scalars <-> components of one Godot Vector3 property (e.g. size); each param names its `component` x|y|z. Godot size convention: x=length, y=height, z=width."
  },
